@model List<UniversitarioTask.Site.Models.Tarefa>
@using UniversitarioTask.Site.Models

<div class="container mt-4">
    
	
	@if (TempData["MensagemSucesso"] != null)
	{
		<div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
			<i class="bi bi-check-circle-fill me-2"></i> @TempData["MensagemSucesso"]
			<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
		</div>
	}

	
	@if (ViewBag.FeriadosDoMes is List<FeriadoModel> feriadosMes && feriadosMes.Any())
	{
		<div class="card mb-4 border-0 shadow-sm" style="background-color: #2c3e50; color: white;">
			<div class="card-body">
				<h6 class="mb-3">
					<i class="bi bi-calendar3 me-2"></i> Feriados de @DateTime.Now.ToString("MMMM")
				</h6>
				<div class="d-flex flex-wrap gap-2">
					@foreach (var f in feriadosMes)
					{
						<div class="p-2 rounded border border-secondary" style="background-color: #34495e;">
							<span class="badge bg-light text-dark me-2">@DateTime.Parse(f.Date).ToString("dd/MM")</span>
							<span class="small fw-bold">@f.Name</span>
						</div>
					}
				</div>
			</div>
		</div>
	}

	
	<div class="card shadow-sm">
		<div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
			<h5 class="mb-0">Minhas Atividades Acadêmicas</h5>
			
			<a asp-action="Adicionar" class="btn btn-secondary btn-sm shadow-sm">Nova Tarefa</a>
		</div>
		<div class="table-responsive">
			<table class="table table-hover align-middle mb-0">
				<thead class="table-light">
					<tr>
						<th>Matéria</th>
						<th>Atividade</th>
						<th>Data de Entrega</th>
						<th>Dificuldade</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in Model.OrderBy(t => t.Data))
					{
						<tr>
							
							<td>@item.Materia</td>
							<td>
								<a href="/Home/Detalhes?id=@item.Id" class="fw-bold text-dark text-decoration-none">
									@item.NomeAtividade
								</a>

								@if (ViewData[$"Alerta_{item.Id}"] != null)
								{
									<div class="text-danger mt-1" style="font-size: 0.8rem;">
										<strong><i class="bi bi-exclamation-triangle"></i> @ViewData[$"Alerta_{item.Id}"]</strong>
									</div>
								}
							</td>
							<td>@item.Data.ToString("dd/MM/yyyy")</td>
							<td>
								<span class="badge bg-@(item.Dificuldade == NivelDificuldade.Dificil ? "danger" : (item.Dificuldade == NivelDificuldade.Medio ? "warning" : "success"))">
									@item.Dificuldade
								</span>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	</div>
</div>
