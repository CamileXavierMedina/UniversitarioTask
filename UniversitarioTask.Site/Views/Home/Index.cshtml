@model List<UniversitarioTask.Site.Models.Tarefa>
@using UniversitarioTask.Site.Models

<div class="container mt-4">
    @if (ViewBag.Feriados is List<FeriadoModel> feriados && feriados.Any())
    {
        <div class="alert alert-light border shadow-sm mb-4">
            <strong>Próximos Feriados:</strong>
            <small class="text-muted">
                @{
                    var topFeriados = feriados.Take(5).Select(f => $"{DateTime.Parse(f.Date):dd/MM} ({f.Name})");
                    @string.Join(", ", topFeriados)
                }
            </small>
        </div>
    }
	<table class="table table-hover shadow-sm">
		<thead class="table-dark">
			<tr>
				<th>Matéria</th>
				<th>Atividade</th>
				<th>Data</th>
				<th>Dificuldade</th>
			</tr>
		</thead>
		<tbody>
			@foreach (var item in Model)
			{
				<tr>
					<td>@item.Materia</td>
					<td>
						
						<a href="/Home/Detalhes?id=@item.Id" class="fw-bold text-decoration-none">
							@item.NomeAtividade
						</a>
					</td>
					<td>@item.Data.ToShortDateString()</td>
					<td>
						<span class="badge bg-@(item.Dificuldade == UniversitarioTask.Site.Models.NivelDificuldade.Dificil ? "danger" : (item.Dificuldade == UniversitarioTask.Site.Models.NivelDificuldade.Medio ? "warning" : "success"))">
							@item.Dificuldade
						</span>
					</td>
				</tr>
			}
		</tbody>
	</table>
</div>
