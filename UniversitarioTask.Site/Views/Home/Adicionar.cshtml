@model UniversitarioTask.Site.Models.Tarefa
@{
	ViewData["Title"] = "Nova Atividade";
}

<div class="container mt-4">
	<div class="card shadow border-0">
		<div class="card-header bg-dark text-white">
			<h4 class="mb-0">Cadastrar Nova Atividade</h4>
		</div>
		<div class="card-body">
			<form asp-action="Adicionar" method="post">
				<div class="row">
					<div class="col-md-6 mb-3">
						<label class="form-label fw-bold">Matéria</label>
						<input name="Materia" type="text" class="form-control" required />
					</div>
					<div class="col-md-6 mb-3">
						<label class="form-label fw-bold">Nome da Atividade</label>
						<input name="NomeAtividade" type="text" class="form-control" required />
					</div>
				</div>
				<div class="row">
					<div class="col-md-4 mb-3">
						<label class="form-label fw-bold">Data de Entrega</label>
						<input name="Data" type="date" class="form-control" required />
					</div>
					<div class="col-md-4 mb-3">
						<label class="form-label fw-bold">Dificuldade</label>
						<select name="Dificuldade" class="form-select">
							<option value="0">Fácil</option>
							<option value="1">Médio</option>
							<option value="2">Difícil</option>
						</select>
					</div>
					<div class="col-md-4 mb-3">
						<label class="form-label fw-bold">Tipo</label>
						<select name="Tipo" class="form-select">
							<option value="0">Prova</option>
							<option value="1">Entrega</option>
						</select>
					</div>
				</div>
				<hr />
				<div class="d-flex justify-content-between">
					<a href="/" class="btn btn-secondary">Cancelar</a>
					<button type="submit" class="btn btn-success px-5">Salvar Atividade</button>
				</div>
			</form>
		</div>
	</div>
</div>
